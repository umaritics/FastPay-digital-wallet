<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.fastpay.DashboardController" styleClass="root-pane">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="brand-panel" prefHeight="70" style="-fx-padding: 10 20 10 20;">
            <Label text="FastPay" styleClass="brand-title" style="-fx-font-size: 24px; -fx-padding: 0;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="LOGOUT" onAction="#handleLogout" styleClass="primary-button" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-width: 2;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="15">
            <Label text="Welcome to your Wallet" styleClass="form-title"/>
            <Label text="Sub-wallets, transactions, and graphs will be built in Sprint 2." style="-fx-text-fill: #666666; -fx-font-size: 14px;"/>
        </VBox>
    </center>
</BorderPane>